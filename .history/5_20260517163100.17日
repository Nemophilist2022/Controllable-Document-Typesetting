.\.venv\Scripts\python.exe -m thesis_agent.cli run --input 论文.docx --profile scau_2024 --mode full
.\.venv\Scripts\python.exe -m thesis_agent.cli run --input 论文.docx --profile scau_2024 --mode eval_only
